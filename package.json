{
  "name": "terminal-tune",
  "displayName": "Terminal Tune",
  "description": "Plays a sound when a terminal command fails.",
  "version": "1.0.0",
  "publisher": "Paivartya Corporation",
  "author": {
    "name": "Parivartya corporation",
    "email": "parivartyacorporation@gmail.com",
    "url": "https://parivartya.in"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "Terminal Sound",
    "Error Sound",
    "Sound",
    "Terminal Error Sound",
    "Sound",
    "Alert",
    "Notification",
    "Error"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminal-tune.testSound",
        "title": "Terminal Tune: Play Test Sound"
      }
    ],
    "configuration": {
      "title": "Terminal Tune",
      "properties": {
        "terminalTune.soundFile": {
          "type": "string",
          "default": "error.wav",
          "enum": [
            "error.wav",
            "ohno.wav",
            "fail.wav",
            "fahhhhh.wav"
          ],
          "description": "Choose a built-in sound from the extension folder."
        },
        "terminalTune.customSoundPath": {
          "type": "string",
          "default": "",
          "description": "Optional: Paste the absolute path to a .wav file on your computer to use a custom sound."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "eslint": "^8.41.0"
  }
}